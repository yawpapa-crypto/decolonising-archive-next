/* =========================
   EDITORIAL DASHBOARD — shared canvas (/workspace shell + /my/* + curator)
   ========================= */

/* Standalone member routes: replace harsh black “matrix” grid with spaced cards */
.workspace-page.dashboard-canvas:not(.curator-workspace) .workspace-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(min(100%, 340px), 1fr));
  gap: 16px;
  border: none;
  background: transparent;
}

.workspace-page.dashboard-canvas:not(.curator-workspace) .workspace-tile {
  border: 1px solid var(--dash-border);
  border-radius: var(--dash-radius-lg);
  background: var(--dash-card);
  box-shadow: none;
  min-height: auto;
}

.workspace-page.dashboard-canvas:not(.curator-workspace) .workspace-header {
  border-bottom: none;
  padding: 24px 28px;
  background: var(--dash-card);
  border: 1px solid var(--dash-border);
  border-radius: var(--dash-radius-lg);
}

.workspace-page.dashboard-canvas:not(.curator-workspace) .workspace-elevated {
  border: 1px solid var(--dash-border);
  background: var(--dash-card);
  border-radius: var(--dash-radius-lg);
  box-shadow: none;
}

/* Curator: soft grid + tiles + metrics (no black 1px matrix) */
.curator-workspace .workspace-grid.workspace-grid-three {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16px;
  border: none;
  background: transparent;
}

.curator-workspace .workspace-grid.workspace-grid-three .span-two {
  grid-column: span 2;
}

.curator-workspace .workspace-tile {
  border: 1px solid var(--dash-border);
  border-radius: var(--dash-radius-lg);
  background: var(--dash-card);
  box-shadow: none;
  min-height: auto;
}

.curator-workspace .workspace-metrics {
  display: grid;
  gap: 12px;
  border: none;
  background: transparent;
}

.curator-workspace .workspace-metrics.curator-metrics-band {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

@media (min-width: 640px) {
  .curator-workspace .workspace-metrics.curator-metrics-band {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
}

@media (min-width: 901px) {
  .curator-workspace .workspace-metrics.curator-metrics-band {
    grid-template-columns: repeat(5, minmax(0, 1fr));
  }
}

.curator-workspace .workspace-metrics > div {
  border-radius: var(--dash-radius);
  border: 1px solid var(--dash-border);
}

.curator-workspace .workspace-analytics-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
  border: none;
  background: transparent;
}

@media (min-width: 720px) {
  .curator-workspace .workspace-analytics-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }
}

.curator-workspace .workspace-analytics-grid > div {
  border-radius: var(--dash-radius);
  border: 1px solid var(--dash-border);
}

.curator-workspace .workspace-elevated {
  border: 1px solid var(--dash-border);
  background: var(--dash-card);
  border-radius: var(--dash-radius-lg);
  box-shadow: none;
}

@media (max-width: 1100px) {
  .curator-workspace .workspace-grid.workspace-grid-three {
    grid-template-columns: 1fr;
  }

  .curator-workspace .workspace-grid.workspace-grid-three .span-two {
    grid-column: span 1;
  }
}

