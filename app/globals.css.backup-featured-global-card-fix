/* -------------------------------------------------------
   Member Bookmarks page polish
   Scoped only to .bookmarks-page
------------------------------------------------------- */

.bookmarks-page {
  --bookmark-ink: #000;
  --bookmark-muted: #666;
  --bookmark-line: #e5e5e5;
  --bookmark-hover: #fafafa;
}

.bookmarks-page .workspace-header {
  background: #fff;
  border: 1px solid var(--bookmark-line);
  border-radius: 20px;
  padding: clamp(1.35rem, 3vw, 2.25rem);
}

.bookmarks-page .workspace-titlebar h1,
.bookmarks-page h1 {
  letter-spacing: -0.04em;
}

.bookmarks-page .workspace-link[href="/workspace"],
.bookmarks-page .workspace-header .workspace-link {
  width: fit-content;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 2.55rem;
  margin-top: 1.25rem;
  border: 1px solid var(--bookmark-line);
  border-radius: 12px;
  background: #fff;
  color: var(--bookmark-ink);
  padding: 0.65rem 0.95rem;
  font-weight: 650;
  text-decoration: none;
  transition:
    background-color 180ms ease,
    border-color 180ms ease,
    transform 180ms ease;
}

.bookmarks-page .workspace-link[href="/workspace"]:hover,
.bookmarks-page .workspace-header .workspace-link:hover {
  background: var(--bookmark-hover);
  border-color: #cfcfcf;
  transform: translateY(-1px);
}

/* Main bookmark container */
.bookmarks-page .workspace-grid,
.bookmarks-page .workspace-tile {
  background: #fff;
  border: 1px solid var(--bookmark-line);
  border-radius: 20px;
}

.bookmarks-page .workspace-tile {
  padding: clamp(1.1rem, 2.2vw, 1.6rem);
  transition:
    border-color 180ms ease,
    box-shadow 180ms ease,
    transform 180ms ease,
    background-color 180ms ease;
}

.bookmarks-page .workspace-tile:hover {
  border-color: #cfcfcf;
  box-shadow: 0 18px 44px rgba(0, 0, 0, 0.035);
}

/* Bookmark item card */
.bookmarks-page .workspace-list,
.bookmarks-page .workspace-list-item {
  width: 100%;
}

.bookmarks-page .workspace-list {
  display: grid;
  gap: 1rem;
}

.bookmarks-page .workspace-list-item {
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  gap: 1rem;
  padding: 1.25rem 0;
  border-top: 1px solid var(--bookmark-line);
}

.bookmarks-page .workspace-list-item:first-child {
  border-top: 0;
}

.bookmarks-page .workspace-list-item > div:first-child {
  display: grid;
  gap: 0.45rem;
  min-width: 0;
}

/* Record title */
.bookmarks-page .workspace-list-item strong {
  display: inline;
  color: var(--bookmark-ink);
  font-size: clamp(1.05rem, 1.4vw, 1.35rem);
  font-weight: 750;
  line-height: 1.25;
  letter-spacing: -0.025em;
  overflow-wrap: anywhere;
}

/* Muted metadata/date that often sits next to title */
.bookmarks-page .workspace-list-item strong + span,
.bookmarks-page .workspace-list-item time {
  color: var(--bookmark-muted);
  font-size: 0.9rem;
  font-weight: 450;
}

/* Note update form */
.bookmarks-page .workspace-list-item form:has(input[name="note"]),
.bookmarks-page .workspace-list-item form:has(textarea[name="note"]) {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 0.75rem;
  align-items: end;
  margin-top: 0.75rem;
}

.bookmarks-page .workspace-list-item form:has(input[name="note"])::before,
.bookmarks-page .workspace-list-item form:has(textarea[name="note"])::before {
  content: "Private note";
  grid-column: 1 / -1;
  color: var(--bookmark-muted);
  font-size: 0.72rem;
  font-weight: 800;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.bookmarks-page .workspace-list-item input[name="note"],
.bookmarks-page .workspace-list-item textarea[name="note"] {
  width: 100%;
  min-height: 2.8rem;
  border: 1px solid var(--bookmark-line);
  border-radius: 12px;
  background: #fff;
  color: var(--bookmark-ink);
  padding: 0.75rem 0.9rem;
  font: inherit;
  font-size: 0.95rem;
  transition:
    border-color 180ms ease,
    box-shadow 180ms ease,
    background-color 180ms ease;
}

.bookmarks-page .workspace-list-item input[name="note"]:focus,
.bookmarks-page .workspace-list-item textarea[name="note"]:focus {
  outline: none;
  border-color: #000;
  box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.06);
}

/* Save note button */
.bookmarks-page .workspace-list-item form:has(input[name="note"]) button,
.bookmarks-page .workspace-list-item form:has(textarea[name="note"]) button {
  min-height: 2.8rem;
  border: 1px solid #000;
  border-radius: 12px;
  background: #000;
  color: #fff;
  padding: 0.75rem 1rem;
  font: inherit;
  font-weight: 650;
  cursor: pointer;
  white-space: nowrap;
  transition:
    background-color 180ms ease,
    border-color 180ms ease,
    transform 180ms ease;
}

.bookmarks-page .workspace-list-item form:has(input[name="note"]) button:hover,
.bookmarks-page .workspace-list-item form:has(textarea[name="note"]) button:hover {
  background: #222;
  border-color: #222;
}

.bookmarks-page .workspace-list-item form:has(input[name="note"]) button:active,
.bookmarks-page .workspace-list-item form:has(textarea[name="note"]) button:active {
  transform: translateY(1px);
}

/* Action row */
.bookmarks-page .workspace-list-item > div:last-child,
.bookmarks-page .workspace-list-item .bookmark-actions {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.75rem;
}

.bookmarks-page .workspace-list-item a,
.bookmarks-page .workspace-list-item form:not(:has(input[name="note"])) button,
.bookmarks-page .workspace-list-item form:not(:has(textarea[name="note"])) button {
  appearance: none;
  border: 1px solid var(--bookmark-line);
  border-radius: 10px;
  background: #fff;
  color: var(--bookmark-ink);
  padding: 0.5rem 0.7rem;
  font: inherit;
  font-size: 0.86rem;
  font-weight: 650;
  text-decoration: none;
  cursor: pointer;
  transition:
    background-color 180ms ease,
    border-color 180ms ease,
    transform 180ms ease,
    color 180ms ease;
}

.bookmarks-page .workspace-list-item a:hover,
.bookmarks-page .workspace-list-item form:not(:has(input[name="note"])) button:hover,
.bookmarks-page .workspace-list-item form:not(:has(textarea[name="note"])) button:hover {
  background: var(--bookmark-hover);
  border-color: #cfcfcf;
  transform: translateY(-1px);
}

/* Delete action */
.bookmarks-page .workspace-list-item form:not(:has(input[name="note"])) button {
  color: #8a1f1f;
}

.bookmarks-page .workspace-list-item form:not(:has(input[name="note"])) button:hover {
  background: #fff7f7;
  border-color: #e5c4c4;
}

/* Empty state */
.bookmarks-page .workspace-empty {
  border: 1px dashed var(--bookmark-line);
  border-radius: 16px;
  background: #fff;
  padding: 1.25rem;
  color: var(--bookmark-muted);
  line-height: 1.5;
}

@media (max-width: 720px) {
  .bookmarks-page .workspace-list-item form:has(input[name="note"]),
  .bookmarks-page .workspace-list-item form:has(textarea[name="note"]) {
    grid-template-columns: 1fr;
  }

  .bookmarks-page .workspace-list-item form:has(input[name="note"]) button,
  .bookmarks-page .workspace-list-item form:has(textarea[name="note"]) button {
    width: 100%;
  }

  .bookmarks-page .workspace-list-item a,
  .bookmarks-page .workspace-list-item form:not(:has(input[name="note"])) button,
  .bookmarks-page .workspace-list-item form:not(:has(textarea[name="note"])) button {
    width: fit-content;
  }
}

@media (prefers-reduced-motion: reduce) {
  .bookmarks-page * {
    transition: none !important;
  }
}


