/* ─── Search suggestions panel ─────────────────────────────────────────── */
.search-bar { position: relative; }

/* Panel: rule is scoped tightly so nothing stains it from elsewhere.
   Using id-level hooks via [id] selectors gives us extra specificity. */
.search-bar .search-suggestions,
.hero-search .search-suggestions,
.search-suggestions[id="searchSuggestions"],
.search-suggestions[id="heroSuggestions"] {
  position: absolute;
  top: calc(100% + 6px);
  left: 0;
  right: 0;
  z-index: 1000;
  margin: 0;
  border: 1px solid #111;
  background: #fff;
  max-height: 420px;
  overflow-y: auto;
  box-shadow: 0 4px 14px rgba(0,0,0,0.06);
  box-sizing: border-box;
}

.search-suggestions.empty,
.search-suggestions[hidden] { display: none; }

/* Items: these selectors are more specific than .hero-search button and
   .search-bar button, so the black-button styling does not bleed in. */
.search-bar .search-suggestion-item,
.hero-search .search-suggestion-item,
.search-suggestions .search-suggestion-item {
  width: 100%;
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: start;
  gap: 20px;
  padding: 14px 18px;
  background: #fff;
  color: #111;
  border: 0;
  border-bottom: 1px solid #e6e6e6;
  border-radius: 0;
  text-align: left;
  cursor: pointer;
  box-sizing: border-box;
  font: inherit;
  line-height: 1.35;
  letter-spacing: normal;
  white-space: normal;
  min-height: auto;
  transition: background .12s;
  /* Prevent the browser from interpreting trackpad taps as pan/scroll
     gestures, which can swallow pointerdown events before they reach
     our handler. `manipulation` allows double-tap zoom but disables the
     300ms click delay some browsers still apply. */
  touch-action: manipulation;
  user-select: none;
  -webkit-user-select: none;
}

/* Children (the label/meta spans) should also not absorb pointer events
   or allow text selection, which can cause the pointerdown target to
   be the span rather than the button and miss our closest() walk. */
.search-suggestion-label,
.search-suggestion-meta {
  pointer-events: none;
  user-select: none;
  -webkit-user-select: none;
}

.search-bar .search-suggestion-item:last-child,
.hero-search .search-suggestion-item:last-child,
.search-suggestions .search-suggestion-item:last-child { border-bottom: 0; }

.search-bar .search-suggestion-item:hover,
.search-bar .search-suggestion-item.active,
.search-bar .search-suggestion-item:focus-visible,
.hero-search .search-suggestion-item:hover,
.hero-search .search-suggestion-item.active,
.hero-search .search-suggestion-item:focus-visible,
.search-suggestions .search-suggestion-item:hover,
.search-suggestions .search-suggestion-item.active,
.search-suggestions .search-suggestion-item:focus-visible {
  background: #f3f3f3;
  color: #111;
  outline: none;
}

.search-suggestions .search-suggestion-label {
  display: block;
  font-size: 15px;
  line-height: 1.35;
  color: #111;
  overflow: hidden;
  text-overflow: ellipsis;
  min-width: 0;
}

.search-suggestions .search-suggestion-meta {
  display: block;
  font-size: 13px;
  line-height: 1.35;
  color: #666;
  white-space: nowrap;
  text-align: right;
  text-transform: capitalize;
}

@media (max-width: 768px) {
  .search-bar .search-suggestion-item,
  .hero-search .search-suggestion-item,
  .search-suggestions .search-suggestion-item {
    grid-template-columns: 1fr;
    gap: 6px;
    padding: 12px 14px;
  }
  .search-suggestions .search-suggestion-meta {
    white-space: normal;
    text-align: left;
  }
  .search-bar .search-suggestions,
  .hero-search .search-suggestions,
  .search-suggestions[id="searchSuggestions"],
  .search-suggestions[id="heroSuggestions"] {
    max-height: 320px;
  }
  .search-suggestions .search-suggestion-label { font-size: 14px; }
  .search-suggestions .search-suggestion-meta { font-size: 12px; }
}

/* ─── Recent searches ──────────────────────────────────────────────────── */
.recent-searches {
  margin-top: 4px;
  margin-bottom: 24px;
  padding-bottom: 18px;
  border-bottom: 1px solid #f0f0f0;
}

/* On the library page, recent searches sit below the search bar.
   When suggestions are showing, we hide the recent-searches block
   to avoid visual stacking and competing signals. */
.search-suggestions:not(.empty):not([hidden]) ~ .recent-searches {
  display: none;
}

/* On the hero, the suggestions panel is inside .hero-search.
   Hide recent searches when hero suggestions are open. */
.hero-search:has(.search-suggestions:not(.empty):not([hidden])) + .recent-searches {
  display: none;
}

/* Hero variant has different context: it sits between the search bar and the
   featured query suggestions, so it doesn't need a bottom rule. */
#heroRecentSearches.recent-searches {
  max-width: 1050px;
  margin-left: auto;
  margin-right: auto;
  margin-top: 20px;
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: 0;
}

.recent-searches-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 16px;
  margin-bottom: 10px;
}

.recent-searches-title {
  font-size: 10px;
  color: #999;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  font-weight: 500;
}

.recent-searches-clear {
  border: 0;
  background: transparent;
  color: #999;
  cursor: pointer;
  font-size: 11px;
  padding: 0;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  font-family: inherit;
  transition: color .15s;
}
.recent-searches-clear:hover { color: #111; }

.recent-searches-list {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  align-items: center;
}

/* Chips: smaller, flatter, with a subtle clock glyph. Uses a CSS mask
   on a pseudo-element to render an inline icon without extra markup. */
.recent-search-chip {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  border: 1px solid #e6e6e6;
  background: #fafafa;
  color: #444;
  padding: 5px 10px 5px 8px;
  font-size: 12px;
  line-height: 1.3;
  cursor: pointer;
  font-family: inherit;
  letter-spacing: 0.01em;
  max-width: 260px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  transition: background .12s, border-color .12s, color .12s;
}

.recent-search-chip::before {
  content: "";
  display: inline-block;
  width: 11px;
  height: 11px;
  flex-shrink: 0;
  background-color: #999;
  -webkit-mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><circle cx='12' cy='12' r='10'/><polyline points='12 6 12 12 16 14'/></svg>");
          mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><circle cx='12' cy='12' r='10'/><polyline points='12 6 12 12 16 14'/></svg>");
  -webkit-mask-repeat: no-repeat;
          mask-repeat: no-repeat;
  -webkit-mask-size: contain;
          mask-size: contain;
  transition: background-color .12s;
}

.recent-search-chip:hover {
  background: #fff;
  border-color: #111;
  color: #111;
}
.recent-search-chip:hover::before {
  background-color: #111;
}

.recent-search-chip:focus-visible {
  outline: none;
  background: #fff;
  border-color: #111;
  color: #111;
}

/* ── Tablet (~768px and below) ─────────────────────────────────────────── */
@media (max-width: 768px) {
  .recent-searches {
    margin-bottom: 20px;
    padding-bottom: 16px;
  }
  #heroRecentSearches.recent-searches {
    margin-top: 16px;
  }
  .recent-search-chip {
    max-width: 220px;
    font-size: 12px;
  }
}

/* ── Phone (~640px and below) ──────────────────────────────────────────── */
@media (max-width: 640px) {
  .recent-searches {
    margin-bottom: 18px;
    padding-bottom: 14px;
  }
  .recent-searches-header { margin-bottom: 8px; }
  .recent-searches-list { gap: 5px; }
  .recent-search-chip {
    font-size: 11px;
    padding: 4px 9px 4px 7px;
    max-width: 180px;
    gap: 6px;
  }
  .recent-search-chip::before { width: 10px; height: 10px; }
  .recent-searches-title { font-size: 9px; letter-spacing: 0.14em; }
