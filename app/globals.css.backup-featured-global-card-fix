/* =========================
   WORKSPACE / CURATOR PAGES
   ========================= */

.workspace-page {
  max-width: 1120px;
  margin: 0 auto;
  padding: 48px 32px 96px;
  display: flex;
  flex-direction: column;
  gap: 32px;
}

.workspace-header {
  display: flex;
  flex-direction: column;
  gap: 10px;
  padding-bottom: 24px;
  border-bottom: var(--border);
}

/* Card-style header on member /my/* + lists when paired with .dashboard-header */
.workspace-header.dashboard-header {
  padding: 24px 28px 26px;
  padding-bottom: 26px;
  margin-bottom: 0;
  border: 1px solid var(--dash-line);
  border-radius: var(--dash-radius-lg);
  border-bottom: 1px solid var(--dash-line);
  background: var(--dash-surface);
  box-shadow: none;
}

.dashboard-shell--member .workspace-page.dashboard-canvas .workspace-titlebar h1 {
  font-size: clamp(1.5rem, 2.4vw, 1.875rem);
  font-weight: 600;
  letter-spacing: -0.02em;
  line-height: 1.2;
  color: var(--dash-ink);
}

.dashboard-shell--member .workspace-page.dashboard-canvas .workspace-eyebrow {
  color: var(--dash-muted);
}

.workspace-eyebrow {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: #8a8a84;
}

.workspace-titlebar {
  display: flex;
  align-items: center;
  gap: 14px;
  flex-wrap: wrap;
}

.workspace-titlebar h1 {
  font-size: clamp(28px, 4vw, 40px);
  font-weight: 400;
  letter-spacing: -.02em;
  line-height: 1.15;
  color: #000;
}

.workspace-sub {
  font-size: 14px;
  color: var(--grey-700);
  line-height: 1.6;
  max-width: 720px;
}

.workspace-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 1px;
  border: var(--border);
  background: #000;
}

.workspace-grid-three {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.workspace-metrics,
.workspace-analytics-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 1px;
  border: var(--border);
  background: #000;
}

.workspace-analytics-grid {
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.workspace-metrics div,
.workspace-analytics-grid div {
  background: #fff;
  padding: 18px 16px;
}

.workspace-metrics span,
.workspace-analytics-grid span {
  display: block;
  font-size: 28px;
  line-height: 1;
  letter-spacing: -.02em;
  color: #000;
  margin-bottom: 8px;
}

.workspace-metrics p,
.workspace-analytics-grid p {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--grey-500);
  margin: 0;
}

.workspace-tile {
  background: #fff;
  padding: 24px 22px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  min-height: 180px;
}

.workspace-tool {
  gap: 18px;
}

.workspace-tile-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 12px;
  flex-wrap: wrap;
}

.workspace-tile h2 {
  font-size: 12px;
  font-weight: 600;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: #000;
}

.workspace-tile p {
  font-size: 13px;
  color: var(--grey-700);
  line-height: 1.6;
}

.workspace-empty {
  font-size: 12px;
  color: var(--grey-500);
  font-style: italic;
}

.workspace-form {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.workspace-form.compact {
  gap: 10px;
}

.workspace-form label {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.workspace-form label > span,
.workspace-check span {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--grey-500);
}

.workspace-form input,
.workspace-form textarea,
.workspace-form select {
  width: 100%;
  min-height: 42px;
  border: 1px solid #000;
  background: #fff;
  color: #000;
  padding: 9px 10px;
  font-size: 13px;
  line-height: 1.4;
  font-family: inherit;
}

.workspace-form textarea {
  resize: vertical;
}

.workspace-check {
  flex-direction: row !important;
  align-items: center;
}

.workspace-check input {
  width: auto;
  min-height: 0;
}

.workspace-wide-form {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12px;
}

.workspace-wide-form .span-two,
.span-two {
  grid-column: span 2;
}

.workspace-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.workspace-list.queue {
  gap: 14px;
}

.workspace-list-item {
  border-top: 1px solid var(--grey-200);
  padding-top: 10px;
  display: flex;
  flex-direction: column;
  gap: 5px;
  min-width: 0;
}

.workspace-list-item.horizontal {
  display: grid;
  grid-template-columns: 1.5fr .7fr .7fr .7fr;
  gap: 12px;
  align-items: center;
}

.workspace-list-item.review-item {
  display: grid;
  grid-template-columns: minmax(0, 1.25fr) minmax(240px, .75fr);
  gap: 18px;
  align-items: start;
}

.workspace-list-item strong {
  font-size: 14px;
  line-height: 1.3;
  color: #000;
  overflow-wrap: anywhere;
}

.workspace-list-item span {
  font-size: 12px;
  line-height: 1.5;
  color: var(--grey-700);
  overflow-wrap: anywhere;
}

.workspace-status {
  display: inline-flex;
  width: fit-content;
  border: 1px solid var(--grey-300);
  background: var(--grey-100);
  color: #000;
  padding: 3px 8px;
  font-size: 10px !important;
  font-weight: 600;
  letter-spacing: .06em;
  text-transform: uppercase;
}

.workspace-status.is-published,
.workspace-status.is-accepted {
  border-color: #196a3b;
  background: #f1fbf4;
  color: #196a3b;
}

.workspace-status.is-review,
.workspace-status.is-in_review {
  border-color: #8a5b00;
  background: #fff8e8;
  color: #8a5b00;
}

.workspace-status.is-declined {
  border-color: #8a0018;
  background: #fff5f5;
  color: #8a0018;
}

.record-workspace-tools {
  background: #fbfbf9;
}

.record-tools-muted,
.record-tools-message {
  font-size: 12px;
  line-height: 1.55;
  color: var(--grey-700);
  margin: 0;
}

.record-tools-message {
  border: 1px solid var(--grey-300);
  background: #fff;
  padding: 8px 10px;
  color: #111;
}

.record-tools-primary {
  min-height: 42px;
  padding: 0 14px;
  border: 1px solid #000;
  background: #000;
  color: #fff;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  margin-top: 12px;
  font-size: 13px;
}

.record-tools-stack {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.record-tool-form {
  border-top: 1px solid var(--grey-200);
  padding-top: 12px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.record-tool-form:first-child {
  border-top: none;
  padding-top: 0;
}

.record-tool-heading {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 10px;
}

.record-tool-heading strong {
  font-size: 13px;
  color: #000;
}

.record-tool-heading span {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--grey-500);
}

.record-tool-form label {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.record-tool-form label > span,
.record-tool-check span {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--grey-500);
}

.record-tool-form input,
.record-tool-form textarea,
.record-tool-form select {
  width: 100%;
  min-height: 40px;
  border: 1px solid #000;
  background: #fff;
  color: #000;
  padding: 8px 10px;
  font-size: 12px;
  line-height: 1.4;
  font-family: inherit;
}

.record-tool-form textarea {
  resize: vertical;
}

.record-tool-check {
  flex-direction: row !important;
  align-items: center;
}

.record-tool-check input {
  width: auto;
  min-height: 0;
}

.record-tool-form button {
  min-height: 40px;
  border: 1px solid #000;
  background: #000;
  color: #fff;
  cursor: pointer;
  font-size: 12px;
  font-family: inherit;
}

.record-tool-form button:hover {
  background: var(--grey-700);
}

.record-actions-wrap {
  margin-top: 1.25rem;
}

.record-actions {
  display: flex;
  align-items: center;
  gap: 0.45rem;
  padding-top: 0.65rem;
  border-top: 0;
}

.card-member-note {
  color: var(--grey-500);
  font-size: 11px;
}

.record-action-icon,
.record-action-inline,
.card-member-select,
.card-member-input {
  border: 1px solid rgba(0,0,0,.18);
  background: #fff;
  color: #111;
  font-family: inherit;
  font-size: 12px;
  line-height: 1.2;
}

.record-action-icon {
  width: 2rem;
  height: 2rem;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition:
    background 160ms ease,
    color 160ms ease,
    border-color 160ms ease,
    transform 160ms ease;
}

.record-action-icon:hover {
  background: #f4f3ef;
  border-color: rgba(0,0,0,.4);
  color: #111;
}

.record-action-icon:active {
  transform: translateY(1px);
}

.record-action-icon.is-active {
  background: #111;
  color: #fff;
  border-color: #111;
}

.record-action-icon:disabled,
.record-action-inline:disabled {
  opacity: 0.45;
  cursor: wait;
}

.record-action-inline {
  min-height: 2rem;
  padding: 0 0.65rem;
  cursor: pointer;
}

.record-action-inline:hover {
  background: #f4f3ef;
  border-color: rgba(0,0,0,.4);
  color: #111;
}

.record-list-create {
  display: flex;
  gap: 0.5rem;
  margin-top: 0.75rem;
  flex-wrap: wrap;
}

.card-member-select {
  min-height: 2rem;
  min-width: 118px;
  padding: 0 8px;
  border-color: #cfcac1;
}

.card-member-input {
  flex: 1;
  min-height: 2rem;
  min-width: 120px;
  padding: 0.65rem 0.75rem;
  border-color: #cfcac1;
  font-size: 0.85rem;
}

.card-member-message {
  flex: 1 1 100%;
  margin-top: 0.4rem;
  color: #7a130f;
  font-size: 11px;
  line-height: 1.35;
}

.search-save-bar {
  align-items: center;
  background: #fbfbf9;
  border: 1px solid var(--grey-200);
  color: var(--grey-700);
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin: 10px 0 12px;
  padding: 8px 10px;
  font-size: 12px;
}

.search-save-form label {
  align-items: center;
  display: flex;
  flex: 1 1 220px;
  gap: 8px;
}

.search-save-form label span {
  color: #000;
  font-weight: 600;
  white-space: nowrap;
}

.search-save-bar input {
  min-height: 34px;
  border: 1px solid var(--grey-300);
  flex: 1 1 180px;
  font-family: inherit;
  font-size: 12px;
  padding: 0 8px;
}

.search-save-bar button {
  min-height: 34px;
  border: 1px solid #000;
  background: #000;
  color: #fff;
  cursor: pointer;
  font-family: inherit;
  font-size: 12px;
  padding: 0 12px;
}

.search-save-message {
  color: #000;
  font-size: 11px;
}

.workspace-profile-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 1px;
  border: var(--border);
  background: #000;
}

.workspace-submit-panel {
  gap: 18px;
}

.workspace-link {
  margin-top: auto;
  font-size: 12px;
  color: #000;
  border-bottom: 1px solid var(--grey-300);
  padding-bottom: 1px;
  align-self: flex-start;
  cursor: pointer;
  background: none;
  border-top: none;
  border-left: none;
  border-right: none;
  font-family: inherit;
  transition: border-color .15s;
}

.workspace-link:hover {
  border-bottom-color: #000;
}

.workspace-link-muted {
  color: var(--grey-500);
  cursor: default;
}

.workspace-link-muted:hover {
  border-bottom-color: var(--grey-300);
}

.workspace-signout {
  color: #b00020;
}

.workspace-elevated {
  border: var(--border);
  background: var(--grey-100);
  padding: 24px 22px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.workspace-elevated h2 {
  font-size: 14px;
  font-weight: 600;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: #000;
}

.workspace-elevated p {
  font-size: 13px;
  color: var(--grey-700);
  line-height: 1.6;
  max-width: 640px;
}

.workspace-actions {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  margin-top: 4px;
}

.workspace-actions-inline {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  align-items: center;
  margin-top: 10px;
}

.workspace-actions-inline form,
.workspace-actions-inline a,
.workspace-actions-inline button {
  margin: 0;
}

.workspace-cta {
  min-height: 44px;
  padding: 0 18px;
  border: 1px solid #000;
  background: #000;
  color: #fff;
  font-size: 13px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background .15s;
  font-family: inherit;
}

.workspace-cta:hover {
  background: var(--grey-700);
}

.workspace-cta-secondary {
  background: #fff;
  color: #000;
}

.workspace-cta-secondary:hover {
  background: var(--grey-100);
}


/* =========================
   AUTH RESPONSIVE
   ========================= */

@media (max-width: 768px) {
  .workspace-grid,
  .workspace-grid-three,
  .workspace-metrics,
  .workspace-analytics-grid,
  .workspace-profile-row,
  .workspace-wide-form {
    grid-template-columns: 1fr;
  }
  .workspace-wide-form .span-two,
  .span-two {
    grid-column: auto;
  }
  .workspace-list-item.horizontal,
  .workspace-list-item.review-item {
    grid-template-columns: 1fr;
  }
  .workspace-page {
    padding: 36px 16px 72px;
    gap: 24px;
  }
  .nav-avatar-menu {
    right: -8px;
    min-width: 220px;
  }
}

@media (max-width: 480px) {
  .auth-card {
    padding: 28px 20px 24px;
  }
  .auth-title {
    font-size: 24px;
  }
}

