.skeleton-link {
  width: 5rem;
  height: 0.9rem;
}

.skeleton-card-title {
  width: 70%;
  height: 1.15rem;
}

.skeleton-small {
  width: 5.5rem;
  height: 0.75rem;
  margin-top: 0.45rem;
}

.skeleton-number {
  width: 3rem;
  height: 1.8rem;
  margin-top: 0.7rem;
}

.skeleton-input {
  width: 100%;
  height: 2.45rem;
  border: 1px solid #ddd6cc;
}

.skeleton-select {
  width: 10rem;
}

.skeleton-button {
  width: 5.5rem;
  height: 2.2rem;
  border: 1px solid #ddd6cc;
}

.skeleton-wide-button {
  width: 8rem;
}

.skeleton-actions {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.skeleton-form-stack {
  display: grid;
  gap: 0.75rem;
  margin-top: 1rem;
}

.skeleton-circle {
  width: 2rem;
  height: 2rem;
  border-radius: 999px;
}

.skeleton-brand {
  width: 7rem;
  height: 1.2rem;
  margin: 1.25rem;
}

.skeleton-nav-stack {
  display: grid;
  gap: 0.45rem;
  padding: 0 1rem;
}

.skeleton-nav-item {
  height: 2.35rem;
  border-radius: 0.75rem;
}

.skeleton-account-block {
  height: 4rem;
  margin: auto 1rem 1rem;
  border-radius: 0.9rem;
}

.workspace-loading-sidebar {
  display: flex;
  flex-direction: column;
}

@media (max-width: 780px) {
  .workspace-loading-sidebar {
    display: none;
  }

  .skeleton-select {
    width: 100%;
  }

  .skeleton-actions,
  .reading-list-toolbar-controls {
    width: 100%;
  }

  .skeleton-button {
    flex: 1;
  }
}

/* Reading list card actions */
.reading-list-card-actions {
  display: inline-flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: flex-end;
  gap: 0.7rem;
}

.reading-list-card-actions form {
  margin: 0;
}

.workspace-tile[id] {
  scroll-margin-top: 7rem;
}

@media (max-width: 720px) {
  .reading-list-card-actions {
    justify-content: flex-start;
  }
}

/* Curator media library */
.curator-media-layout {
  display: grid;
  grid-template-columns: minmax(18rem, 0.85fr) minmax(0, 1.5fr);
  gap: 1rem;
  margin-top: 1.25rem;
}

.curator-media-upload,
.curator-media-library {
  min-width: 0;
}

.curator-media-library-head {
  display: flex;
  flex-wrap: wrap;
  align-items: flex-end;
  justify-content: space-between;
  gap: 12px;
}

.curator-media-filter {
  flex: 1;
  min-width: min(100%, 240px);
  margin: 0;
}

.curator-media-filter-empty {
  grid-column: 1 / -1;
  padding: 0.75rem 0;
}

.curator-media-grid {
  display: grid;
  gap: 1rem;
}

.curator-media-card {
  display: grid;
  grid-template-columns: 9rem minmax(0, 1fr);
  gap: 1rem;
  padding: 1rem;
  border: 1px solid #e2ded5;
  background: #fffdf8;
}

.curator-media-preview {
  min-height: 7rem;
  border: 1px solid #e2ded5;
  background: #f6f5f2;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.curator-media-preview img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.curator-media-file {
  padding: 0.75rem;
  color: #5f5b53;
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.curator-media-body {
  min-width: 0;
}

.curator-media-body h3 {
  margin: 0 0 0.35rem;
  font-size: 1rem;
}

.curator-media-body p {
  margin: 0.25rem 0;
  color: #5f5b53;
  font-size: 0.88rem;
  line-height: 1.5;
}

.curator-media-meta {
  color: #7a746a;
  font-size: 0.78rem;
}

.curator-media-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.65rem;
  margin-top: 0.8rem;
}

.curator-media-actions a,
.curator-media-actions button {
  appearance: none;
  border: 0;
  background: transparent;
  color: #111;
  padding: 0;
  font: inherit;
  font-size: 0.84rem;
  text-decoration: underline;
  text-underline-offset: 3px;
  cursor: pointer;
}

.curator-media-actions a:hover,
.curator-media-actions button:hover {
  color: #5f5b53;
}

@media (max-width: 900px) {
  .curator-media-layout {
    grid-template-columns: 1fr;
  }

  .curator-media-card {
    grid-template-columns: 1fr;
  }

  .curator-media-preview {
    min-height: 12rem;
  }
}

/* Curator media previews and links */
.curator-upload-preview {
  border: 1px solid #e2ded5;
  background: #fffdf8;
  padding: 0.75rem;
}

.curator-upload-preview img {
  display: block;
  width: 100%;
  max-height: 18rem;
  object-fit: cover;
  border: 1px solid #e2ded5;
}

.curator-upload-file-preview {
  display: grid;
  gap: 0.25rem;
  color: #5f5b53;
}

.curator-upload-file-preview strong {
  color: #111;
}

.curator-media-card-head {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  align-items: start;
}

.curator-media-card-head span {
  border: 1px solid #d8d1c6;
  background: #f6f5f2;
  color: #4f4a43;
  padding: 0.25rem 0.4rem;
  font-size: 0.68rem;
  font-weight: 800;
  letter-spacing: 0.08em;
}

.curator-media-used-in {
  margin-top: 0.85rem;
  padding: 0.75rem;
  border: 1px solid #e4ded3;
  background: #fff;
}

.curator-media-used-in strong {
  display: block;
  margin-bottom: 0.4rem;
  font-size: 0.78rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.curator-media-used-in ul {
  margin: 0;
  padding-left: 1rem;
}

.curator-media-used-in li {
  margin-bottom: 0.3rem;
  color: #5f5b53;
  font-size: 0.82rem;
}

.curator-media-link-panel {
  margin-top: 1rem;
  padding: 1rem;
  border: 1px solid #e2ded5;
  background: #f6f5f2;
}

.curator-media-link-panel h4 {
  margin: 0;
  font-size: 1rem;
}

.curator-media-link-form {
  display: grid;
  gap: 0.8rem;
  margin-top: 0.85rem;
}

.curator-media-link-form label {
  display: grid;
  gap: 0.35rem;
}

.curator-media-link-form label span {
  color: #5f5b53;
  font-size: 0.72rem;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.curator-media-link-form input,
.curator-media-link-form select {
  width: 100%;
  border: 1px solid #d8d1c6;
  background: #fffdf8;
  color: #111;
  padding: 0.62rem 0.7rem;
  font: inherit;
}

.curator-media-link-form input:focus,
.curator-media-link-form select:focus {
  outline: none;
  border-color: #111;
  box-shadow: 0 0 0 3px rgba(17, 17, 17, 0.08);
}

/* Curator workspace editorial editors */
.curator-editor-stack {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  margin-top: 1rem;
  max-height: min(70vh, 42rem);
  overflow-y: auto;
  padding-right: 0.25rem;
}

.curator-editor-card {
  border: 1px solid #e2ded5;
  background: #fff;
  padding: 1rem 1.1rem;
  border-radius: 2px;
}

.curator-editor-card-queue {
  grid-column: 1 / -1;
}

.curator-editor-header {
  margin-bottom: 0.85rem;
}

.curator-editor-title-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.5rem 0.75rem;
}

.curator-editor-heading {
  font-size: 1rem;
  font-weight: 600;
  margin: 0;
  flex: 1 1 12rem;
  min-width: 0;
}

.curator-editor-meta {
  margin: 0.35rem 0 0;
  font-size: 0.78rem;
  color: #7a746a;
}

.curator-pathway-link-block {
  margin: 0.65rem 0 0;
  display: grid;
  gap: 0.35rem;
}

.curator-pathway-link-label {
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  color: #7a746a;
}

.curator-pathway-link-url {
  display: block;
  font-size: 0.72rem;
  word-break: break-all;
  padding: 0.45rem 0.55rem;
  border: 1px solid #e8e4dc;
  background: #fcfcfa;
  color: #333;
}

.curator-pathway-copy {
  justify-self: start;
}

.curator-status-badge {
  display: inline-flex;
  align-items: center;
  border: 1px solid #d8d1c6;
  background: #f6f5f2;
  color: #3a3834;
  padding: 0.2rem 0.45rem;
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.curator-status-badge.note-type {
  text-transform: none;
  letter-spacing: 0.02em;
  font-weight: 600;
  font-size: 0.72rem;
}

.curator-unsaved-badge {
  border: 1px solid #111;
  background: #fffdf8;
  color: #111;
  padding: 0.2rem 0.45rem;
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.curator-editor-form {
  display: grid;
  gap: 0.65rem;
}

.curator-editor-form label {
  display: grid;
  gap: 0.32rem;
}

.curator-editor-form label span {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: #5f5b53;
}

.curator-editor-form input,
.curator-editor-form select,
.curator-editor-form textarea {
  width: 100%;
  border: 1px solid #d8d1c6;
  background: #fffdf8;
  color: #111;
  padding: 0.55rem 0.65rem;
  font: inherit;
  border-radius: 2px;
}

.curator-editor-form input:focus,
.curator-editor-form select:focus,
.curator-editor-form textarea:focus {
  outline: none;
  border-color: #111;
  box-shadow: 0 0 0 3px rgba(17, 17, 17, 0.07);
}

.curator-editor-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.6rem 0.75rem;
  align-items: center;
  margin-top: 0.85rem;
}

.curator-secondary-button {
  appearance: none;
  border: 1px solid #111;
  background: #fff;
  color: #111;
  padding: 0.45rem 0.85rem;
  font: inherit;
  font-size: 0.82rem;
  cursor: pointer;
  border-radius: 2px;
}

.curator-secondary-button:hover:not(:disabled) {
  background: #fcfcfa;
}

.curator-secondary-button:disabled {
  opacity: 0.45;
  cursor: not-allowed;
}

.curator-danger-button {
  appearance: none;
  border: 1px solid #8b2e2e;
  background: #fff;
  color: #8b2e2e;
  padding: 0.45rem 0.85rem;
  font: inherit;
  font-size: 0.82rem;
  cursor: pointer;
  border-radius: 2px;
}

.curator-danger-button:hover:not(:disabled) {
  background: #fff8f8;
}

.curator-danger-button:disabled {
  opacity: 0.45;
  cursor: not-allowed;
}

.curator-empty-compact {
  margin: 0;
  padding: 0.5rem 0;
}

.curator-queue-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem 1rem;
  font-size: 0.78rem;
  color: #7a746a;
  margin: 0.35rem 0 0;
}

.curator-queue-description {
  margin: 0.5rem 0;
  font-size: 0.88rem;
  color: #444;
  line-height: 1.5;
}

.curator-queue-source {
  margin: 0 0 0.5rem;
}

.curator-queue-hint {
  margin: 0.75rem 0 0;
  font-size: 0.75rem;
  color: #7a746a;
  line-height: 1.45;
}

.curator-submissions-queue {
  gap: 1rem;
}

@media (max-width: 720px) {
  .curator-editor-actions {
    flex-direction: column;
    align-items: stretch;
  }

  .curator-editor-actions .workspace-cta,
  .curator-secondary-button,
  .curator-danger-button {
    width: 100%;
    text-align: center;
  }
}

/* ----- Slice C: curator polish (metrics, badges, charts, media) ----- */

.curator-metrics-band.workspace-metrics div {
  transition: background 0.15s ease;
}

.curator-metrics-band.workspace-metrics div:hover {
  background: #fafafa;
}

.curator-metrics-band.workspace-metrics div:focus-within {
  outline: none;
}

.curator-pipeline-panel {
  margin-top: 1rem;
  border: 1px solid var(--dash-border);
  background: var(--dash-card);
  padding: 1rem 1.15rem 1.15rem;
  border-radius: var(--dash-radius-lg);
}

.curator-pipeline-panel-inner {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 1.25rem;
}

.curator-mini-chart-block {
  min-width: 0;
}

.curator-mini-chart-title {
  margin: 0 0 0.25rem;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #5f5b53;
}

.curator-mini-chart-sub {
  margin: 0 0 0.75rem;
  font-size: 0.78rem;
  color: #7a746a;
  line-height: 1.45;
}

.curator-mini-chart {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0.55rem;
}

.curator-mini-chart li {
  display: grid;
  grid-template-columns: 5.5rem minmax(0, 1fr) 2rem;
  align-items: center;
  gap: 0.5rem;
}

.curator-mini-chart-label {
  font-size: 0.72rem;
  color: #5f5b53;
}

.curator-mini-chart-track {
  height: 8px;
  background: #ece8e0;
  border-radius: 1px;
  overflow: hidden;
}

.curator-mini-chart-fill {
  height: 100%;
  border-radius: 1px;
  min-width: 2px;
  transition: width 0.35s ease;
}

.curator-mini-chart-fill.is-draft {
  background: #6b6560;
}

.curator-mini-chart-fill.is-review {
  background: #b8860b;
}

.curator-mini-chart-fill.is-published {
  background: #1a1a1a;
}

.curator-mini-chart-fill.is-queue {
  background: #4a6fa5;
}

.curator-mini-chart-fill.is-accepted {
  background: #2d6a4f;
}

.curator-mini-chart-fill.is-declined {
  background: #9b4d4d;
}

.curator-mini-chart-value {
  font-size: 0.78rem;
  font-weight: 600;
  color: #111;
  text-align: right;
}

.curator-empty-state {
  padding: 0.75rem 0 0.25rem;
}

.curator-empty-title {
  margin: 0 0 0.35rem;
  font-size: 0.82rem;
  font-weight: 600;
  font-style: normal;
  color: #444;
}

.curator-empty-hint {
  margin: 0;
  font-size: 0.8rem;
  line-height: 1.5;
  color: #7a746a;
  font-style: normal;
}

.curator-media-empty .curator-empty-title {
  margin-bottom: 0.45rem;
}

/* Status badges: editorial tones + quiet hover */
.curator-status-badge {
  transition: border-color 0.15s ease, background 0.15s ease, color 0.15s ease;
}

.curator-status-badge:hover {
  border-color: #111;
  background: #fff;
}

.curator-status-badge.is-draft {
  background: #f3f2ef;
  border-color: #c9c4bc;
  color: #4a4640;
}

.curator-status-badge.is-review {
  background: #faf6eb;
  border-color: #d4c49a;
  color: #6b5a2a;
}

.curator-status-badge.is-published {
  background: #f0f0ee;
  border-color: #111;
  color: #111;
}

.curator-status-badge.is-archived {
  background: #f5f5f5;
  border-color: #bdbdbd;
  color: #616161;
}

.curator-status-badge.is-active {
  background: #eef4ef;
  border-color: #a8c4b2;
  color: #2d4a38;
}

.curator-status-badge.is-inactive {
  background: #f4f4f4;
  border-color: #ccc;
  color: #666;
}

.curator-status-badge.is-submitted,
.curator-status-badge.is-in_review {
  background: #f2f4fa;
  border-color: #b4c0dc;
  color: #3d4d6b;
}

.curator-status-badge.is-accepted {
  background: #eef6f1;
  border-color: #9dc4ae;
  color: #2a5c40;
}

.curator-status-badge.is-declined {
  background: #faf0f0;
  border-color: #dcb4b4;
  color: #7a3a3a;
}

.curator-unsaved-badge {
  transition: transform 0.12s ease, box-shadow 0.12s ease;
}

.curator-unsaved-badge:hover {
  box-shadow: 0 1px 0 rgba(17, 17, 17, 0.12);
}

/* Editor cards: lift on hover, focus rings */
.curator-editor-card {
  transition: border-color 0.18s ease, box-shadow 0.18s ease;
}

.curator-editor-card:hover {
  border-color: #cfc7bb;
  box-shadow: 0 2px 14px rgba(17, 17, 17, 0.05);
}

.curator-editor-form input:focus-visible,
.curator-editor-form select:focus-visible,
.curator-editor-form textarea:focus-visible {
  outline: 2px solid #111;
  outline-offset: 1px;
}

.curator-secondary-button:focus-visible,
.curator-danger-button:focus-visible,
.curator-pathway-copy:focus-visible {
  outline: 2px solid #111;
  outline-offset: 2px;
}

.curator-secondary-button:hover:not(:disabled) {
  border-color: #111;
}

.curator-danger-button:hover:not(:disabled) {
  border-color: #6b2020;
  color: #6b2020;
}

.workspace-cta:focus-visible {
  outline: 2px solid #111;
  outline-offset: 2px;
}

/* Media library: cover ribbon + usage strip */
.curator-media-preview {
  position: relative;
}

.curator-media-cover-ribbon {
  position: absolute;
  top: 0.45rem;
  left: 0.45rem;
  z-index: 2;
  font-size: 0.62rem;
  font-weight: 800;
  letter-spacing: 0.09em;
  text-transform: uppercase;
  padding: 0.18rem 0.38rem;
  border: 1px solid #111;
  background: rgba(255, 253, 248, 0.94);
  color: #111;
  pointer-events: none;
}

.curator-media-card:hover .curator-media-preview img {
  filter: brightness(0.98);
}

.curator-media-usage-mix {
  display: flex;
  width: 100%;
  height: 7px;
  border-radius: 1px;
  overflow: hidden;
  margin: 0.5rem 0 0;
  border: 1px solid #e4ded3;
  background: #f0ebe3;
}

.curator-media-usage-seg {
  display: block;
  min-width: 4px;
  transition: opacity 0.15s ease;
}

.curator-media-usage-seg:hover {
  opacity: 0.85;
}

.curator-media-usage-seg.is-record {
  background: #5c7a99;
}

.curator-media-usage-seg.is-dossier {
  background: #8b7355;
}

.curator-media-usage-seg.is-pathway {
  background: #6b8e6b;
}

.curator-media-usage-seg.is-collection {
  background: #8b7aa8;
}

.curator-media-usage-seg.is-featured_record {
  background: #c49a6c;
}

.curator-media-usage-seg.is-archive_note {
  background: #9b8aa4;
}

.curator-media-usage-seg.is-other {
  background: #888;
}

.curator-used-in-list {
  list-style: none;
  margin: 0.35rem 0 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0.45rem;
}

.curator-used-in-list li {
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  gap: 0.35rem 0.5rem;
  font-size: 0.78rem;
  line-height: 1.35;
  color: #444;
}

.curator-used-in-pill {
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: 0.12rem 0.35rem;
  border: 1px solid #d8d1c6;
  background: #fff;
  color: #5f5b53;
}

.curator-used-in-target {
  display: inline-flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.35rem;
}

.curator-used-in-type {
  color: #7a746a;
}

.curator-used-in-id {
  font-size: 0.72rem;
  padding: 0.1rem 0.28rem;
  border: 1px solid #e8e4dc;
  background: #fcfcfa;
  color: #222;
}

.curator-used-in-caption {
  flex-basis: 100%;
  margin-left: 0;
  color: #7a746a;
  font-size: 0.74rem;
}

.curator-media-actions a:focus-visible,
.curator-media-actions button:focus-visible {
  outline: 2px solid #111;
  outline-offset: 2px;
  border-radius: 1px;
}

@media (max-width: 900px) {
  .curator-pipeline-panel-inner {
    grid-template-columns: 1fr;
  }

  .curator-mini-chart li {
    grid-template-columns: 4.75rem minmax(0, 1fr) 1.75rem;
