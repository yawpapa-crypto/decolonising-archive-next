/* =========================
   MEMBER DASHBOARD SYSTEM
   Scoped to /workspace and member management pages.
   ========================= */

.member-dashboard-shell {
  --member-bg: #f7f7f7;
  --member-surface: #ffffff;
  --member-ink: #050505;
  --member-muted: #666666;
  --member-faint: #9a9a9a;
  --member-line: #e6e6e6;
  --member-line-strong: #cfcfcf;
  --member-hover: #f3f3f3;
  --member-accent: #dfff00;
  --member-accent-soft: rgba(223, 255, 0, 0.36);
  --member-accent-line: rgba(169, 199, 0, 0.48);
  --member-radius: 18px;
  --member-radius-sm: 12px;
  --member-transition: 180ms cubic-bezier(0.22, 1, 0.36, 1);
  display: grid;
  grid-template-columns: 264px minmax(0, 1fr);
  min-height: calc(100vh - 105px);
  background: var(--member-bg);
  color: var(--member-ink);
}

.member-dashboard-sidebar {
  position: sticky;
  top: 52px;
  height: calc(100vh - 52px);
  align-self: start;
  border-right: 1px solid var(--member-line);
  background: rgba(255, 255, 255, 0.86);
  backdrop-filter: blur(18px);
  padding: 1.25rem;
}

.member-dashboard-main {
  min-width: 0;
}

.member-dashboard-content,
.member-dashboard-main > .member-dashboard-header {
  width: min(100%, 1260px);
  margin-inline: auto;
}

.member-dashboard-content {
  display: grid;
  gap: 1.15rem;
  padding: 0 1.5rem 2rem;
}

.member-dashboard-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 1rem;
  margin: 1.5rem auto 1.15rem;
  padding: 1.35rem;
  border: 1px solid var(--member-line);
  border-radius: var(--member-radius);
  background: var(--member-surface);
}

.member-dashboard-eyebrow {
  margin: 0 0 0.45rem;
  color: var(--member-muted);
  font-size: 0.68rem;
  font-weight: 800;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.member-dashboard-header h1 {
  margin: 0;
  color: var(--member-ink);
  font-size: clamp(1.85rem, 3vw, 2.65rem);
  font-weight: 700;
  line-height: 1.05;
  letter-spacing: 0;
}

.member-dashboard-header p {
  max-width: 720px;
  margin: 0.65rem 0 0;
  color: var(--member-muted);
  font-size: 0.95rem;
  line-height: 1.55;
}

.member-dashboard-header-pills,
.member-dashboard-header-actions,
.member-dashboard-actions {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.55rem;
}

.member-dashboard-header-pills {
  margin-top: 0.9rem;
}

.member-dashboard-header-actions {
  justify-content: flex-end;
}

.member-dashboard-pill {
  display: inline-flex;
  align-items: center;
  width: fit-content;
  max-width: 100%;
  min-height: 1.65rem;
